{
  "name": "tgc-screen-mcp",
  "version": "1.1.0",
  "description": "MCP server for controlling The Golf Club 2019 — launch, screen capture, OCR, keyboard input, and voice control via WSL↔Windows interop",
  "author": "Adam Ruf <ruf0385@gmail.com>",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tgc-screen-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';let c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);fs.chmodSync(f,0o755)\"",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --port 3100",
    "start:voice": "node dist/index.js --voice",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "express": "^5.2.1",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "mcp",
    "golf",
    "tgc-2019",
    "the-golf-club",
    "screen-capture",
    "ocr",
    "automation",
    "simulator",
    "voice-control",
    "golf-simulator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ruf0385/tgc-screen-mcp.git"
  }
}
